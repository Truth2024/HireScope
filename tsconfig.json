{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@styles/*": ["src/shared/styles/*"],
      "@lib/*": ["src/shared/lib/*"],
      "@components": ["src/shared/components/index.ts"],
      "@ui": ["src/shared/ui/index.ts"],
      "@models/*": ["mongo/models/*"],
      "@store/*": ["src/shared/store/*"],
      "@providers/*": ["src/shared/providers/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "mongo/seed.js"
  ],
  "exclude": ["node_modules"]
}

{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@styles/*": ["src/shared/styles/*"],
      "@lib/*": ["src/shared/lib/*"],
      "@constants/*": ["src/shared/constants/*"],
      "@myTypes/*": ["src/shared/types/*"],
      "@i18n/*": ["src/i18n/*"],
      "@components": ["src/shared/components/index.ts"],
      "@ui": ["src/shared/ui/index.ts"],
      "@models/*": ["mongo/models/*"],
      "@store/*": ["src/shared/store/*"],
      "@providers/*": ["src/shared/providers/*"],
      "@headerComponents": ["src/shared/components/Header/components/index.ts"],
      "@commentsComponents": [
        "src/app/[locale]/(baseLayout)/(public)/vacancies/[vacancyId]/components/Comments/components/index.ts"
      ],
      "@commentsStore": [
        "src/app/[locale]/(baseLayout)/(public)/vacancies/[vacancyId]/components/Comments/store/commentsStore.ts"
      ],
      "@candidatesStore": [
        "src/app/[locale]/(baseLayout)/(public)/candidates/store/CandidatesStore.ts"
      ],
      "@vacanciesStore": [
        "src/app/[locale]/(baseLayout)/(public)/vacancies/store/VacanciesStore.ts"
      ],
      "@vacanciesHooks/*": ["src/app/[locale]/(baseLayout)/(public)/vacancies/hooks/*"],
      "@vacanciesComponents/*": ["src/app/[locale]/(baseLayout)/(public)/vacancies/components/*"],
      "@candidatesHooks/*": ["src/app/[locale]/(baseLayout)/(public)/candidates/hooks/*"],
      "@candidatesComponents/*": ["src/app/[locale]/(baseLayout)/(public)/candidates/components/*"],
      "@candidatesProvider/*": ["src/app/[locale]/(baseLayout)/(public)/candidates/provider/*"],
      "@candidatesStore/*": ["src/app/[locale]/(baseLayout)/(public)/candidates/store/*"],
      "@ProfileClientComponents": [
        "src/app/[locale]/(baseLayout)/(protected)/profile/components/ProfileClient/components/index.ts"
      ],
      "@experienceStore/*": [
        "src/app/[locale]/(baseLayout)/(protected)/profile/(candidate)/main/components/ExperienceChanger/store/*"
      ],
      "@experienceSchema/*": [
        "src/app/[locale]/(baseLayout)/(protected)/profile/(candidate)/main/components/ExperienceChanger/schema/*"
      ],
      "@profileMainCandidate": [
        "src/app/[locale]/(baseLayout)/(protected)/profile/(candidate)/main/components/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "mongo/seed.js",
    "src/shared/constants/skills.js"
  ],
  "exclude": ["node_modules"]
}
